# Bar Flores environment variables.
# Copy this file to .env (gitignored) and fill in the values for local dev.
# In production on Replit, set these via Tools -> Secrets instead.

# Postgres connection string. On Replit, this is provisioned automatically
# when you enable the Postgres integration. For local dev, point at any
# Neon / local Postgres instance.
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Long random string used to sign session cookies. In production the server
# will refuse to boot if this is missing (see server/index.ts). Generate one
# with: openssl rand -base64 48
SESSION_SECRET=

# Password for the single admin user ("admin") on the /dashboard-login page.
# In production the server will refuse to boot if this is missing.
DASHBOARD_PASSWORD=

# Object storage (used for the per-menu hero image uploads via the Replit
# object storage sidecar). Required only if you want admins to upload images
# rather than paste URLs. See server/replit_integrations/object_storage/.
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public
PRIVATE_OBJECT_DIR=/your-bucket/private

# Server port. Replit overrides this automatically; default 5000 for local dev.
PORT=5000

# NODE_ENV — "development" enables Vite middleware mode; "production" enables
# the fail-fast checks above and serves the built static bundle.
NODE_ENV=development
